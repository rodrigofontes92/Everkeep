@page
@model ChangePasswordModel

@{
    ViewData["Title"] = "Palavra-passe";
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;
}

<div class="manage-content-inner">

    <!-- TÍTULO -->
    <div class="mb-4">

        <h2>
            Alterar palavra-passe
        </h2>

        <p>
            Para manter a sua conta segura, escolha uma palavra-passe forte e fácil de recordar.
        </p>

    </div>

    <!-- STATUS -->
    <partial name="_StatusMessage" for="StatusMessage" />

    <!-- FORM -->
    <form id="change-password-form" method="post">

        <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

        <!-- ATUAL -->
        <div class="form-group mb-4">

            <label class="form-label-everkeep">
                Palavra-passe atual
            </label>

            <input asp-for="Input.OldPassword"
                   class="form-control everkeep-input"
                   type="password"
                   placeholder="Introduza a palavra-passe atual" />

            <span asp-validation-for="Input.OldPassword" class="text-danger"></span>

        </div>

        <!-- NOVA -->
        <div class="form-group mb-4">

            <label class="form-label-everkeep">
                Nova palavra-passe
            </label>

            <input asp-for="Input.NewPassword"
                   class="form-control everkeep-input"
                   type="password"
                   placeholder="Introduza a nova palavra-passe" />

            <span asp-validation-for="Input.NewPassword" class="text-danger"></span>

        </div>

        <!-- CONFIRMAR -->
        <div class="form-group mb-4">

            <label class="form-label-everkeep">
                Confirmar nova palavra-passe
            </label>

            <input asp-for="Input.ConfirmPassword"
                   class="form-control everkeep-input"
                   type="password"
                   placeholder="Repita a nova palavra-passe" />

            <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>

        </div>

        <!-- BOTÃO -->
        <div class="text-center mt-4">

            <button type="submit"
                    class="btn btn-everkeep">

                Atualizar palavra-passe

            </button>

        </div>

    </form>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}