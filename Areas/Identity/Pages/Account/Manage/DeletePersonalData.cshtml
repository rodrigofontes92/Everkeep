@page
@model DeletePersonalDataModel

@{
    ViewData["Title"] = "Eliminar conta";
    ViewData["ActivePage"] = ManageNavPages.PersonalData;
}

<div class="manage-content-inner">

    <!-- TÍTULO -->
    <div class="mb-4">

        <h2>
            Eliminar conta
        </h2>

        <p>
            Esta ação irá remover permanentemente a sua conta e tudo o que guardou no Everkeep.
        </p>

    </div>

    <!-- AVISO -->
    <div class="everkeep-alert danger mb-4">

        <strong>
            Atenção:
        </strong>

        <p style="margin-top:6px; margin-bottom:0;">
            Esta ação é irreversível. Depois de eliminar a sua conta, não será possível recuperar os seus dados.
        </p>

    </div>

    <!-- FORM -->
    <form id="delete-user" method="post">

        <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

        @if (Model.RequirePassword)
        {
            <div class="form-group mb-4">

                <label class="form-label-everkeep">
                    Confirme a sua palavra-passe
                </label>

                <input asp-for="Input.Password"
                       type="password"
                       class="form-control everkeep-input"
                       placeholder="Introduza a sua palavra-passe" />

                <span asp-validation-for="Input.Password" class="text-danger"></span>

            </div>
        }

        <!-- AÇÕES -->
        <div class="text-center mt-4 d-flex justify-content-center gap-3">

            <button class="btn btn-outline-danger"
                    type="submit">

                Eliminar conta

            </button>

            <a asp-page="./PersonalData"
                   class="btn btn-everkeep">

                Voltar atrás

            </a>

        </div>

    </form>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}