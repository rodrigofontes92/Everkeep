@page
@model EnableAuthenticatorModel

@{
    ViewData["Title"] = "Aplicação autenticadora";
    ViewData["ActivePage"] = ManageNavPages.TwoFactorAuthentication;
}

<div class="manage-content-inner">

    <!-- TÍTULO -->
    <div class="mb-4">

        <h2>
            Configurar segurança adicional
        </h2>

        <p>
            Pode usar uma aplicação no seu telemóvel para proteger ainda mais a sua conta.
        </p>

    </div>

    <partial name="_StatusMessage" for="StatusMessage" />

    <!-- PASSOS -->
    <div class="everkeep-card p-4 mb-4">

        <h4 class="section-title mb-3">
            Passo a passo
        </h4>

        <ol class="everkeep-steps">

            <!-- PASSO 1 -->
            <li>
                Instale uma aplicação autenticadora no seu telemóvel, como:
                <br />
                Microsoft Authenticator ou Google Authenticator.
            </li>

            <!-- PASSO 2 -->
            <li>
                Faça a leitura do código abaixo com a aplicação.

                <div class="mt-3 text-center">
                    <div id="qrCode"></div>
                </div>

                <p class="mt-3" style="color:#777;">
                    Se preferir, pode introduzir manualmente esta chave:
                </p>

                <div class="everkeep-key text-center">
                    @Model.SharedKey
                </div>

                <div id="qrCodeData" data-url="@Model.AuthenticatorUri"></div>
            </li>

            <!-- PASSO 3 -->
            <li>
                Introduza o código gerado pela aplicação para confirmar:
            </li>

        </ol>

    </div>

    <!-- FORM -->
    <form id="send-code" method="post">

        <div class="form-group mb-4">

            <label class="form-label-everkeep">
                Código de verificação
            </label>

            <input asp-for="Input.Code"
                   class="form-control everkeep-input"
                   placeholder="Ex: 123456"
                   autocomplete="off" />

            <span asp-validation-for="Input.Code" class="text-danger"></span>

        </div>

        <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

        <!-- BOTÃO -->
        <div class="text-center mt-4">

            <button type="submit"
                    class="btn btn-everkeep">

                Confirmar código

            </button>

        </div>

    </form>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}