@page
@model LoginModel
@{
    ViewData["Title"] = "Iniciar sessão";
}

<div class="container fade-in">

    <div class="row justify-content-center">

        <div class="col-md-6 col-lg-5">

            <div class="everkeep-card p-4">

                <!-- TÍTULO -->
                <div class="text-center mb-4">
                    <h2 class="hero-title" style="font-size: 36px;">
                        Bem-vindo de volta
                    </h2>

                    <p class="hero-subtitle">
                        Entre no seu espaço e revisite o que realmente importa.
                    </p>
                </div>

                <!-- FORMULÁRIO -->
                <form method="post">

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <!-- EMAIL -->
                    <div class="form-group mb-3">
                        <label asp-for="Input.Email" class="form-label">Email</label>
                        <input asp-for="Input.Email" class="form-control everkeep-input" placeholder="o.seu@email.com" />
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>

                    <!-- PASSWORD -->
                    <div class="form-group mb-2">
                        <label asp-for="Input.Password" class="form-label">Palavra-passe</label>
                        <input asp-for="Input.Password" class="form-control everkeep-input" placeholder="A sua palavra-passe" />
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>

                    <!-- LEMBRAR -->
                    <div class="form-group form-check mb-4 text-start">
                        <input class="form-check-input" asp-for="Input.RememberMe" />
                        <label class="form-check-label" asp-for="Input.RememberMe">
                            Manter sessão iniciada
                        </label>
                    </div>

                    <!-- BOTÃO -->
                    <div class="text-center">
                        <button type="submit" class="btn btn-everkeep w-100">
                            Entrar
                        </button>
                    </div>

                </form>

                <!-- APOIO -->
                <div class="text-center mt-4">

                    <p style="color:#666;">
                        Ainda não tem conta?
                    </p>

                    <a asp-page="./Register" class="everkeep-link">
                        Criar conta
                    </a>

                </div>

            </div>

        </div>

    </div>

</div>